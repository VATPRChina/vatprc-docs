{
  "name": "vatprc-docs",
  "type": "module",
  "version": "0.1.0",
  "engines": {
    "node": ">=v22.11.0"
  },
  "packageManager": "pnpm@11.5.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:api": "openapi-typescript https://uniapi.vatprc.net/openapi.json -o src/lib/api.d.ts && prettier --write src/lib/api.d.ts",
    "build:api-local": "openapi-typescript ../vatprc-uniapi/openapi.json -o src/lib/api.d.ts && prettier --write src/lib/api.d.ts",
    "start": "vite start",
    "lint": "concurrently --raw 'pnpm:lint:*'",
    "lint:eslint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:tsc": "tsc --noEmit",
    "lint:prettier": "prettier --check .",
    "format": "prettier --write .",
    "test": "vitest",
    "ui:add": "shadcn add",
    "test:browser": "vitest --workspace=vitest.workspace.ts",
    "i18n:extract": "lingui extract --clean"
  },
  "dependencies": {
    "@date-fns/utc": "^2.1.1",
    "@lingui/core": "^6.3.0",
    "@lingui/react": "^6.3.0",
    "@mantine/core": "^9.3.1",
    "@mantine/dates": "^9.3.1",
    "@mantine/dropzone": "^9.3.1",
    "@mantine/hooks": "^9.3.1",
    "@mantine/notifications": "^9.3.1",
    "@mdx-js/mdx": "^3.1.1",
    "@scalar/api-reference-react": "^0.9.46",
    "@sentry/react": "^10.57.0",
    "@sentry/tanstackstart-react": "^10.57.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@stefanprobst/remark-extract-toc": "^2.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-start": "^1.168.25",
    "@tanstack/react-table": "^8.21.3",
    "@turf/turf": "^7.3.5",
    "@vis.gl/react-maplibre": "^8.1.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "es-iterator-helpers": "^1.3.3",
    "github-slugger": "^2.0.0",
    "jotai": "^2.20.1",
    "maplibre-gl": "^5.24.0",
    "openapi-fetch": "^0.17.0",
    "openapi-react-query": "^0.5.4",
    "radash": "^12.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "rehype-external-links": "^3.0.0",
    "rehype-github-alerts": "^4.2.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "tailwindcss": "^4.3.1",
    "typescript-eslint": "^8.61.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@lingui/babel-plugin-lingui-macro": "^6.3.0",
    "@lingui/cli": "^6.3.0",
    "@lingui/vite-plugin": "^6.3.0",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-lingui": "^0.14.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "nitro": "3.0.260610-beta",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vitest-browser-react": "^2.2.0"
  },
  "prettier": {
    "printWidth": 120,
    "plugins": [
      "@trivago/prettier-plugin-sort-imports",
      "prettier-plugin-tailwindcss"
    ]
  }
}
